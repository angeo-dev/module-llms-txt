{
    "name": "angeo/module-llms-txt",
    "version": "2.1.3",
    "description": "Magento 2 module for AI Engine Optimization (AEO). Generates spec-compliant llms.txt and llms-full.txt per llmstxt.org standard, plus JSONL for vector indexing. Multi-store, CLI, cron, Admin UI.",
    "keywords": [
        "magento2",
        "magento module",
        "angeo",
        "aeo",
        "llms.txt",
        "ai-commerce",
        "ai-search",
        "chatgpt",
        "claude",
        "gemini"
    ],
    "homepage": "https://angeo.dev/",
    "support": {
        "email": "support@angeo.dev"
    },
    "authors": [
        {
            "name": "Ievgenii Gryshkun",
            "email": "info@angeo.dev",
            "homepage": "https://angeo.dev/"
        }
    ],
    "type": "magento2-module",
    "require": {
        "php": ">=8.1",
        "magento/framework": "*",
        "magento/module-store": "*",
        "magento/module-catalog": "*",
        "magento/module-cms": "*",
        "magento/module-backend": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "license": ["MIT"],
    "autoload": {
        "files": ["registration.php"],
        "psr-4": {
            "Angeo\\LlmsTxt\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Angeo\\LlmsTxt\\Test\\": "Test/"
        }
    }
}
